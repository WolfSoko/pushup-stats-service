# pnpm configuration for monorepo
# https://pnpm.io/npmrc
# Require lockfile for reproducible installs
frozen-lockfile=true

# Use pnpm workspace protocol for local dependencies
prefer-workspace-packages=true

# Strict node resolution - fail if peer deps not satisfied
strict-peer-dependencies=false

# Enable shamefully-hoist for compatibility with Nx monorepo tools
shamefully-hoist=true

# Configure registry (change if using private registries)
# registry=https://registry.npmjs.org/

# Enable pre-release versions for Angular Fire RC
# (optional, only if needed for development)
# tag-version-prefix=v
