{
  "name": "web",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "web/src",
  "implicitDependencies": ["data-store"],
  "i18n": {
    "sourceLocale": "de",
    "locales": {
      "en": {
        "translation": "web/src/locale/messages.en.xlf",
        "subPath": "en"
      }
    },
    "defaultLocale": "de"
  },
  "tags": ["scope:app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "dependsOn": ["tools:generate-sitemap"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/web",
        "browser": "web/src/main.ts",
        "server": "web/src/main.server.ts",
        "outputMode": "server",
        "localize": true,
        "allowedCommonJsDependencies": ["pino", "pino-http"],
        "ssr": {
          "entry": "web/src/server.ts",
          "experimentalPlatform": "node"
        },
        "polyfills": ["@angular/localize/init"],
        "tsConfig": "web/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "web/public"
          },
          {
            "glob": "sw-push.js",
            "input": "web/src",
            "output": "/"
          }
        ],
        "styles": ["web/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "localize": ["de", "en"],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1755kb",
              "maximumError": "2048kb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "sourceMap": true,
          "serviceWorker": "web/ngsw-config.json"
        },
        "production-preview": {
          "localize": ["de", "en"],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "4755kb",
              "maximumError": "8048kb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kb",
              "maximumError": "16kb"
            }
          ],
          "optimization": false,
          "sourceMap": true,
          "serviceWorker": "web/ngsw-config.json"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        },
        "development-emulator": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "web/src/env/firebase-runtime.ts",
              "with": "web/src/env/firebase-runtime.emulator.ts"
            }
          ]
        },
        "staging": {
          "localize": ["de", "en"],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "web/src/env/fire.config.ts",
              "with": "web/src/env/fire.config.staging.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "proxyConfig": "web/proxy.conf.json"
      },
      "configurations": {
        "production": {
          "buildTarget": "web:build:production"
        },
        "development": {
          "buildTarget": "web:build:development"
        },
        "development-emulator": {
          "buildTarget": "web:build:development-emulator"
        },
        "staging": {
          "buildTarget": "web:build:staging"
        }
      },
      "defaultConfiguration": "development"
    },
    "serve-local": {
      "continuous": true,
      "executor": "nx:run-commands",
      "dependsOn": ["data-store:serve"],
      "options": {
        "command": "npx nx run web:serve:development-emulator"
      }
    },
    "serve-live": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nx run web:serve:development"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "tsConfig": "web/tsconfig.spec.json",
        "coverage": true,
        "watch": false
      }
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "web:build:production",
        "format": "xlf2",
        "outputPath": "web/src/locale",
        "outFile": "messages.xlf"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "web:build",
        "staticFilePath": "dist/web",
        "spa": true
      }
    }
  }
}
