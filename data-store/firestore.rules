rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Signed-in users may only read/write their own config document.
    match /userConfigs/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.userId == userId;
    }

    // Pushup entries are user-owned.
    // Public read is allowed for the SEO demo user so SSR can render preview pages.
    // Public read for SEO demo user (UID: aqgzwSbhudRLrluz1zBSW3XQx013).
    match /pushups/{pushupId} {
      allow read: if resource.data.userId == 'aqgzwSbhudRLrluz1zBSW3XQx013'
                  || (request.auth != null && resource.data.userId == request.auth.uid);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Public leaderboard snapshot: readable by everyone, writable only via Admin SDK (Cloud Functions).
    match /leaderboards/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Motivation quotes are owner-only. Writes are server-only (Admin SDK).
    match /motivationQuotes/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Web Push subscriptions — owner-only, no public access.
    // Writes are handled exclusively by Cloud Functions (Admin SDK).
    match /pushSubscriptions/{userId}/subs/{subId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only Cloud Functions (Admin SDK) write here
    }

    // Precomputed user statistics — readable by owner, writable only via Admin SDK (Cloud Functions).
    match /userStats/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only Cloud Functions (Admin SDK) write here
    }

    // Reminder dispatch state — internal only, no client access.
    match /reminderDispatchState/{userId} {
      allow read, write: if false; // Cloud Functions (Admin SDK) only
    }

    // Feedback — create-only for authenticated users. No read/update/delete from client.
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['message', 'name', 'email', 'userId', 'userAgent', 'createdAt'])
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 5000
                    && (request.resource.data.userId == null
                        || request.resource.data.userId == request.auth.uid)
                    && (!request.resource.data.keys().hasAny(['name'])
                        || request.resource.data.name == null
                        || (request.resource.data.name is string
                            && request.resource.data.name.size() <= 100))
                    && (!request.resource.data.keys().hasAny(['email'])
                        || request.resource.data.email == null
                        || (request.resource.data.email is string
                            && request.resource.data.email.size() <= 320));
      allow read, update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
