{
  "functions": {
    "source": "functions"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "functions": {
      "port": 5001
    },
    "ui": {
      "enabled": true
    },
    "hub": {
      "port": 4400
    }
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "hosting-public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "redirects": [
      {
        "source": "/",
        "destination": "/de",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/de{,/**}",
        "destination": "/de/index.html"
      },
      {
        "source": "/en{,/**}",
        "destination": "/en/index.html"
      }
    ]
  },
  "apphosting": {
    "backendId": "pushup-stats-service",
    "rootDir": "../",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "data-store/functions"
    ]
  }
}
