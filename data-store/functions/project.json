{
  "name": "cloud-functions",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "data-store/functions/src",
  "tags": ["scope:cloud-functions"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "data-store/functions-dist",
        "main": "data-store/functions/src/index.ts",
        "tsConfig": "data-store/functions/tsconfig.app.json",
        "platform": "node",
        "target": "node24",
        "format": ["cjs"],
        "bundle": true,
        "thirdParty": false,
        "generatePackageJson": true,
        "sourceMap": true,
        "assets": []
      }
    },
    "test": {
      "options": {
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    },
    "lint": {
      "inputs": [
        "default",
        "{workspaceRoot}/.eslintrc.json",
        "{workspaceRoot}/.eslintignore",
        "{workspaceRoot}/eslint.config.mjs",
        {
          "externalDependencies": ["eslint"]
        }
      ]
    },
    "generate-exercise-rules": {
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/data-store/firestore.rules",
        "{workspaceRoot}/libs/stats/src/lib/models/exercise.catalog.ts",
        "{projectRoot}/src/exercise-rules-codegen.ts",
        "{projectRoot}/src/exercise-rules-codegen.run.cjs"
      ],
      "outputs": ["{workspaceRoot}/data-store/firestore.rules"],
      "options": {
        "command": "node data-store/functions/src/exercise-rules-codegen.run.cjs",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
