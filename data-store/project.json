{
  "name": "data-store",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "data-store/src",
  "tags": ["scope:data-store"],
  "implicitDependencies": ["cloud-functions"],
  "targets": {
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "dependsOn": ["cloud-functions:build"],
      "options": {
        "cwd": "data-store",
        "command": "bash -lc 'echo $$ > .firebase-emulators.pid; exec npx firebase emulators:start --only auth,firestore,functions'"
      }
    },
    "emulate": {
      "continuous": true,
      "executor": "nx:run-commands",
      "dependsOn": ["cloud-functions:build"],
      "options": {
        "cwd": "data-store",
        "command": "bash -lc 'echo $$ > .firebase-emulators.pid; exec npx firebase emulators:start --only auth,firestore,functions'"
      }
    },
    "emulate:stop": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "data-store",
        "command": "../tools/firebase/stop-emulators.sh"
      }
    },
    "emulate:smoke": {
      "executor": "nx:run-commands",
      "dependsOn": ["cloud-functions:build"],
      "options": {
        "cwd": "data-store",
        "command": "npx firebase emulators:exec --only auth,firestore,functions \"echo emulator-ok\""
      }
    },
    "deploy:functions": {
      "executor": "nx:run-commands",
      "dependsOn": ["cloud-functions:build"],
      "options": {
        "cwd": "data-store",
        "command": "npx firebase deploy --only functions"
      }
    }
  }
}
