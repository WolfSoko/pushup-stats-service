{
  "name": "tools",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "tools/src",
  "projectType": "library",
  "tags": ["scope:tools"],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "tools/jest.config.cjs"
      }
    },
    "import-user-configs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/src/import-user-configs-to-firestore.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "export-nedb-user-configs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/src/export-nedb-user-configs.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "generate-sitemap": {
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/web/src/app/blog/blog-posts.data.ts",
        "{workspaceRoot}/content/blog/**/*.md",
        "{workspaceRoot}/tools/src/generate-sitemap.js"
      ],
      "outputs": ["{workspaceRoot}/web/public/sitemap.xml"],
      "dependsOn": ["generate-content"],
      "options": {
        "command": "node tools/src/generate-sitemap.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "test-xliff-sync": {
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/tools/src/sync-xliff.py",
        "{workspaceRoot}/tools/src/sync-xliff.spec.py"
      ],
      "options": {
        "command": "python3 tools/src/sync-xliff.spec.py",
        "cwd": "{workspaceRoot}"
      }
    },
    "generate-content": {
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/content/blog/**/*.md",
        "{workspaceRoot}/content/wiki/pushup-types/*.md",
        "{workspaceRoot}/tools/src/generate-content.mjs"
      ],
      "outputs": [
        "{workspaceRoot}/web/src/app/blog/generated",
        "{workspaceRoot}/libs/stats/src/lib/models/pushup-type-content.generated.ts"
      ],
      "options": {
        "command": "node tools/src/generate-content.mjs",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
